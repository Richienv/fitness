// Prisma schema — will be migrated to Neon once DATABASE_URL is provisioned.
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model DailyLog {
  id        String   @id @default(cuid())
  date      String   @unique
  gymDay    Boolean  @default(false)
  checklist Json     @default("{}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model MealEntry {
  id         String   @id @default(cuid())
  date       String
  mealType   String
  items      Json
  totals     Json
  createdAt  DateTime @default(now())

  @@index([date])
}

model WorkoutSession {
  id          String     @id @default(cuid())
  date        String
  sessionType String
  totalVolume Float      @default(0)
  exercises   Exercise[]
  createdAt   DateTime   @default(now())

  @@index([date])
}

model Exercise {
  id        String         @id @default(cuid())
  sessionId String
  name      String
  sets      Json
  session   WorkoutSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

model Measurement {
  id          String   @id @default(cuid())
  date        String   @unique
  weightKg    Float?
  waistCm     Float?
  shoulderCm  Float?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([date])
}

model ActivityLog {
  id         String   @id @default(cuid())
  actor      String
  action     String
  entityId   String?
  entityType String?
  payload    Json?
  createdAt  DateTime @default(now())

  @@index([actor, createdAt])
}

// Shared food library — web custom foods and Hermes-discovered foods both
// land here so every client (and the bot) sees the same catalogue.
model FoodItem {
  id        String   @id @default(cuid())
  name      String
  per100g   Json
  source    String   @default("richie-web")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([name])
}
